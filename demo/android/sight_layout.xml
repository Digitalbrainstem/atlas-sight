<?xml version="1.0" encoding="utf-8"?>
<!--
  Atlas Sight — Full-screen camera layout with invisible touch overlay.
  Designed for visually impaired users: minimal visual UI, large status text,
  high contrast. All interaction is via touch gestures + voice.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- Camera preview — full screen background -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3" />

    <!-- Status overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Top spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Status indicator dot -->
        <View
            android:id="@+id/status_dot"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@android:color/holo_green_light"
            android:layout_marginTop="48dp" />

        <!-- Status text -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Initializing…"
            android:textColor="#B3FFFFFF"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            android:importantForAccessibility="yes" />

        <!-- Middle spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="3" />

        <!-- Description text (main content area) -->
        <TextView
            android:id="@+id/description_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6FFFFFF"
            android:textSize="22sp"
            android:lineSpacingMultiplier="1.4"
            android:textAlignment="center"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:accessibilityLiveRegion="assertive" />

        <!-- Bottom spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="3" />

        <!-- Mode badge -->
        <TextView
            android:id="@+id/mode_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Atlas Sight"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="48dp" />

    </LinearLayout>

    <!-- Touch overlay — captures all gestures -->
    <View
        android:id="@+id/touch_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Atlas Sight. Double tap to describe scene. Long press to ask a question."
        android:focusable="true"
        android:clickable="true" />

</FrameLayout>
